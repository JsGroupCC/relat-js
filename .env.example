# ─── Supabase ────────────────────────────────────────────────────────────────
# Pegue em https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Apenas server-side. NUNCA exponha ao client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── LLM ─────────────────────────────────────────────────────────────────────
# Provider primário: openai | anthropic
LLM_PRIMARY_PROVIDER=openai

# OpenAI (primário) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (fallback) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
